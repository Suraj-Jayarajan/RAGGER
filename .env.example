# Project
PROJECT_NAME=RAGGER
ENVIRONMENT=local
LOG_LEVEL=info

# Frontend
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:5173
API_VERSION=0.1.0
API_V1_PREFIX=/api/v1
DEBUG=true
PYTHON_VERSION=3.12

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=ragger
POSTGRES_PASSWORD=ragger_password
POSTGRES_DB=ragger_db
DATABASE_URL=postgresql+psycopg://ragger:ragger_password@postgres:5432/ragger_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=ragger_redis_password
REDIS_URL=redis://:ragger_redis_password@redis:6379/0

# Qdrant
QDRANT_HOST=qdrant
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://qdrant:6333

# Future: Neo4j
NEO4J_HOST=localhost
NEO4J_BOLT_PORT=7687
NEO4J_HTTP_PORT=7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=ragger_neo4j_password

# Future: MinIO
MINIO_HOST=localhost
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=ragger
MINIO_ROOT_PASSWORD=ragger_minio_password

# Future: Celery
CELERY_BROKER_URL=redis://:ragger_redis_password@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:ragger_redis_password@localhost:6379/2

# JWT Authentication
SECRET_KEY=supersecretkey
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Future: LangGraph
LANGGRAPH_ENV=local
